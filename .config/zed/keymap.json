// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "ctrl-p": [
        "task::Spawn",
        {
          "task_name": "file_finder",
          "reveal_target": "center"
        }
      ],
      "ctrl-shift-f": [
        "task::Spawn",
        {
          "task_name": "fulltext_search",
          "reveal_target": "center"
        }
      ],
      "ctrl-alt-b ": "workspace::ToggleLeftDock",
      "ctrl-b": "workspace::ToggleRightDock",
      "ctrl-t": "workspace::NewTerminal"
    }
  },
  {
    "context": "Editor",
    "bindings": {}
  },
  {
    "context": "Editor && edit_prediction_conflict",
    "bindings": {
      "ctrl-enter": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "Editor && edit_prediction",
    "bindings": {
      // Here we also allow `alt-enter` to accept the prediction
      "alt-enter": "editor::AcceptEditPrediction"
    }
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-r": "project_panel::Rename"
    }
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-r": "editor::Rename"
    }
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-t": "terminal_panel::Toggle"
    }
  }
]
// CTRL-W close active item (file)
