{
  "$schema": "https://raw.githubusercontent.com/zigtools/zls/refs/tags/0.15.0/schema.json",
  // Theme
  "theme": {
    "dark": "BetterOneDark (default)",
    "light": "One Light",
    "mode": "dark"
  },
  "icon_theme": "Light Charmed Icons",
  "ui_font_size": 16,
  "colorize_brackets": true,
  "base_keymap": "VSCode",
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 17.0,
  "buffer_line_height": "comfortable",
  "cursor_blink": false,
  // Languages
  "inlay_hints": {
    "edit_debounce_ms": 700,
    "enabled": false,
    "scroll_debounce_ms": 50,
    "show_other_hints": true,
    "show_parameter_hints": true,
    "show_type_hints": true
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always"
          }
        }
      },
      "enable_lsp_tasks": true
    },
    "zls": {
      "force_autofix": true,
      "warn_style": true,
      "highlight_global_var_declarations": true
    },
    "clangd": {
      "binary": {
        "arguments": [
          "--query-driver=/usr/bin/x86_64-w64-mingw32-gcc"
        ]
      }
    },
    "gopls": {
      "initialization_options": {
        "gofumpt": true
      }
    },
    "pyright": {
      "settings": {
        "python": {
          "pythonPath": "~/.venv/bin/python"
        }
      }
    },
    "languages": {}
  },
  "languages": {
    "C++": {
      "show_edit_predictions": false
    },
    "C": {
      "show_edit_predictions": false
    },
    "Zig": {
      "formatter": "language_server",
      "show_edit_predictions": false,
      "format_on_save": "on",
      "language_servers": [
        "zls"
      ]
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": [
            "--write",
            "--stdin-filepath"
          ]
        }
      }
    }
  },
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "prettier": {
    "allowed": true
  },
  // AI
  "completions": {
    "words_min_length": 2
  },
  "agent": {
    "favorite_models": [
      {
        "provider": "copilot_chat",
        "model": "claude-sonnet-4.6",
        "enable_thinking": false
      },
      {
        "provider": "copilot_chat",
        "model": "gpt-5-mini",
        "enable_thinking": false
      }
    ],
    "play_sound_when_agent_done": true,
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4.6"
    },
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini"
    },
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": [],
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "mode": "subtle"
  },
  "use_system_path_prompts": false,
  "use_system_prompts": false,
  "show_edit_predictions": true,
  // Git
  "git": {
    "inline_blame": {
      "show_commit_summary": true
    }
  },
  "git_panel": {
    "tree_view": true,
    "dock": "right"
  },
  // UI
  "status_bar": {
    "cursor_position_button": false,
    "experimental.show": false
  },
  "file_finder": {
    "modal_max_width": "large"
  },
  "title_bar": {
    "show_file_path": "when_multiple_tabs"
  },
  "gutter": {
    "runnables": false,
    "min_line_number_digits": 0
  },
  "sticky_scroll": {
    "enabled": true
  },
  "indent_guides": {
    "coloring": "indent_aware",
    "enabled": true
  },
  "project_panel": {
    "hide_root": true,
    "starts_open": true,
    "auto_fold_dirs": false,
    "sticky_scroll": true,
    "auto_reveal_entries": true,
    "button": true,
    "default_width": 240,
    "dock": "right",
    "file_icons": true,
    "folder_icons": true,
    "git_status": true,
    "indent_size": 20,
    "scrollbar": {
      "show": "never"
    },
    "indent_guides": {
      "show": "never"
    }
  },
  "tabs": {
    "close_position": "right",
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "errors"
  },
  "terminal": {
    "alternate_scroll": "off",
    "blinking": "terminal_controlled",
    "button": false,
    "copy_on_select": true,
    "detect_venv": {
      "on": {
        "directories": [
          ".env",
          "env",
          ".venv",
          "venv"
        ]
      }
    },
    "dock": "bottom",
    "font_family": "JetBrainsMono Nerd Font Mono",
    "line_height": "comfortable",
    "option_as_meta": true,
    "shell": "system",
    "toolbar": {},
    "working_directory": "current_project_directory"
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": true
  },
  "tab_bar": {
    "show": false
  },
  "centered_layout": {
    "left_padding": 0.15,
    "right_padding": 0.15
  },
  // Functions
  "middle_click_paste": false,
  "double_click_in_multibuffer": "open",
  "redact_private_values": false,
  "autosave": "on_focus_change",
  "confirm_quit": true,
  "hide_mouse": "on_typing_and_movement",
  "show_wrap_guides": true,
  "soft_wrap": "editor_width",
  "relative_line_numbers": "enabled",
  "format_on_save": "on",
  "formatter": "language_server",
  "extend_comment_on_newline": false,
  "horizontal_scroll_margin": 1,
  "verical_scroll_margin": 1,
  "when_closing_with_no_tabs": "keep_window_open",
  // Vim
  "vim_mode": true,
  "vim": {
    "enable_vim_sneak": true
  },
  // Other
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  }
}
